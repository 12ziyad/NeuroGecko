  <tendon>
    <!-- spine: one fixed tendon couples the 3 lateral joints into a
         smooth lizard S-curve (single actuator). Spatial routing is a
         future muscle-level upgrade. [R] -->
    <fixed name="spine_bend" stiffness="0.01" damping="0.004">
      <joint joint="spine_lat_1" coef="1.0"/>
      <joint joint="spine_lat_2" coef="1.0"/>
      <joint joint="spine_lat_3" coef="0.8"/>
    </fixed>
    <!-- tail: LEFT/RIGHT antagonist pair over the 5 yaw joints
         (muscle-like push-pull). Opposite-sign coefs; co-activation
         stiffens, differential bends. High joint damping prevents whip. -->
    <fixed name="tail_bend_L" stiffness="0.008" damping="0.005">
      <joint joint="tail_yaw_1" coef="1"/>
      <joint joint="tail_yaw_2" coef="0.94"/>
      <joint joint="tail_yaw_3" coef="0.88"/>
      <joint joint="tail_yaw_4" coef="0.82"/>
      <joint joint="tail_yaw_5" coef="0.76"/>
    </fixed>
    <fixed name="tail_bend_R" stiffness="0.008" damping="0.005">
      <joint joint="tail_yaw_1" coef="-1"/>
      <joint joint="tail_yaw_2" coef="-0.94"/>
      <joint joint="tail_yaw_3" coef="-0.88"/>
      <joint joint="tail_yaw_4" coef="-0.82"/>
      <joint joint="tail_yaw_5" coef="-0.76"/>
    </fixed>
